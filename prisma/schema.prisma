generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReadingStatus {
    PLAN_TO_READ
    READING
    COMPLETED
    ON_HOLD
    DROPPED
}

enum MangaStatus {
    ONGOING
    COMPLETED
    HIATUS
    CANCELLED
}

enum UserRole {
    USER
    CONTRIBUTOR
    MODERATOR
    ADMIN
    SUPER_ADMIN
}

enum ApprovalStatus {
    PENDING
    APPROVED
    REJECTED
    CANCELLED
}

enum MangaWorkflowStatus {
    DRAFT
    PENDING_REVIEW
    APPROVED
    REJECTED
    PUBLISHED
    ARCHIVED
}

model User {
    id          String           @id @default(uuid())
    name        String
    email       String        @unique
    password    String
    photo       String?
    role        UserRole      @default(USER)
    roleGrantedAt DateTime?
    roleGrantedById String?
    reviews     Review[]
    favorites   Favorite[]
    readingList ReadingList[]
    roleGrantedBy User?       @relation("RoleGrantedBy", fields: [roleGrantedById], references: [id], onDelete: SetNull)
    grantedUsers User[]       @relation("RoleGrantedBy")
    applications CreatorApplication[]
    reviewedApplications CreatorApplication[] @relation("ApplicationReviewedBy")
    createdMangas Manga[]     @relation("MangaCreatedBy")
    updatedMangas Manga[]     @relation("MangaUpdatedBy")
    approvedMangas Manga[]    @relation("MangaApprovedBy")
    author Author?
    moderationActions MangaModerationLog[] @relation("ModerationActionBy")
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    deletedAt   DateTime?

    @@index([role])
    @@index([roleGrantedById])
    @@index([deletedAt])
}

model Manga {
    id               String           @id @default(uuid())
    title            String        @unique
    authorId         String
    authorProfile    Author        @relation(fields: [authorId], references: [id], onDelete: Restrict)
    description      String?
    status           MangaStatus   @default(ONGOING)
    type             String        @default("manga")
    readingDirection String        @default("rtl")
    genre            String[]
    publishedYear    Int
    coverImagePath   String?
    coverImageMime   String?
    coverImageSize   Int?
    coverImageChecksum String?
    viewsCount       Int           @default(0)
    favoritesCount   Int           @default(0)
    reviewsCount     Int           @default(0)
    averageRating    Float         @default(0)
    lastChapterAt    DateTime?
    workflowStatus   MangaWorkflowStatus @default(DRAFT)
    createdById      String
    updatedById      String?
    approvedById     String?
    submittedAt      DateTime?
    approvedAt       DateTime?
    publishedAt      DateTime?
    rejectedAt       DateTime?
    rejectionReason  String?
    reviews          Review[]
    favorites        Favorite[]
    readingList      ReadingList[]
    chapters         Chapter[]
    moderationLogs   MangaModerationLog[]
    createdBy        User          @relation("MangaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
    updatedBy        User?         @relation("MangaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
    approvedBy       User?         @relation("MangaApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
    createdAt        DateTime      @default(now())
    updatedAt        DateTime      @updatedAt
    deletedAt        DateTime?

    @@index([title])
    @@index([authorId])
    @@index([publishedYear])
    @@index([status])
    @@index([workflowStatus])
    @@index([createdById])
    @@index([approvedById])
    @@index([lastChapterAt])
    @@index([deletedAt])
}

model CreatorApplication {
    id            String            @id @unique @default(uuid())
    userId        String       @unique
    requestedRole UserRole       @default(CONTRIBUTOR)
    status        ApprovalStatus @default(PENDING)
    justification String?
    portfolioUrl  String?
    reviewedById  String?
    reviewedAt    DateTime?
    decisionNote  String?
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    reviewedBy    User?          @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([status])
    @@index([requestedRole])
    @@index([reviewedById])
    @@index([createdAt])
}

model MangaModerationLog {
    id             String                @id @default(uuid())
    mangaId        String              @unique
    actionById     String
    action         String
    fromStatus     MangaWorkflowStatus?
    toStatus       MangaWorkflowStatus?
    note           String?
    createdAt      DateTime           @default(now())

    manga          Manga              @relation(fields: [mangaId], references: [id], onDelete: Cascade)
    actionBy       User               @relation("ModerationActionBy", fields: [actionById], references: [id], onDelete: Restrict)

    @@index([mangaId])
    @@index([actionById])
    @@index([createdAt])
}

model Author {
    id        String      @id
    name      String   @unique
    slug      String   @unique
    bio       String?
    userEmail String   @unique
    user      User     @relation(fields: [id], references: [id], onDelete: Cascade)
    mangas    Manga[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?

    @@index([name])
    @@index([userEmail])
}

model Review {
    id        String      @id @default(uuid())
    rating    Int
    comment   String
    userId    String
    mangaId   String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?

    @@unique([userId, mangaId])
    @@index([userId])
    @@index([mangaId])
    @@index([deletedAt])
}

model Favorite {
    id        String      @id @default(uuid())
    userId    String         @unique
    mangaId   String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    deletedAt DateTime?

    @@unique([userId, mangaId])
    @@index([userId])
    @@index([mangaId])
    @@index([deletedAt])
}

model ReadingList {
    id        String           @id @default(uuid())
    userId    String           @unique
    mangaId   String
    status    ReadingStatus @default(PLAN_TO_READ)
    user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    manga     Manga         @relation(fields: [mangaId], references: [id], onDelete: Cascade)
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
    deletedAt DateTime?

    @@unique([userId, mangaId])
    @@index([userId])
    @@index([mangaId])
    @@index([status])
    @@index([deletedAt])
}

model Chapter {
    id        String      @id @default(uuid())
    title     String    @unique
    mangaId   String @unique
    number    Int @unique
    slug      String?
    language  String   @default("pt-BR")
    pages     Page[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?

    manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

    @@unique([mangaId, number])
    @@unique([mangaId, slug])
    @@index([mangaId])
    @@index([mangaId, number])
    @@index([deletedAt])
}

model Page {
    id             String      @id @default(uuid())
    chapterId      String
    number         Int
    orderIndex     Int?
    isDoublePage   Boolean  @default(false)
    imagePath      String
    imageMimeType  String?
    imageSizeBytes Int?
    checksum       String?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    deletedAt      DateTime?

    chapter        Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

    @@unique([chapterId, number])
    @@unique([checksum])
    @@unique([imagePath])
    @@index([chapterId])
    @@index([orderIndex])
    @@index([checksum])
    @@index([deletedAt])
}